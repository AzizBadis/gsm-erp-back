generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TECHNICIAN
  CASHIER
  STAFF
}

enum RepairStatus {
  RECEIVED
  ASSIGNED
  IN_PROGRESS
  PAUSED
  WAITING_PARTS
  PARTS_READY
  FINISHED
  DELIVERED
  CANCELLED
}

enum PartRequestStatus {
  PENDING
  APPROVED
  REJECTED
  DELIVERED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum EssentialTaskStatus {
  NEW
  DONE
}

enum EssentialTaskPriority {
  MEDIUM
  HIGH
  URGENT
}

enum PurchaseKind {
  REQUEST
  ORDER
  PURCHASE
  RETURN
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  RETURNED
  CANCELLED
}

enum PurchasePaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum InvoiceDocumentType {
  SALE
  DRAFT
  QUOTE
  RETURN
}

enum StockTransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum StockAdjustmentType {
  ADD
  SUBTRACT
}

enum AccountTransactionDirection {
  DEBIT
  CREDIT
}

enum ReservationStatus {
  WAITING
  BOOKED
  ARRIVED
  CANCELLED
}

enum AbonnementStatus {
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  fullName     String
  role         UserRole
  roleId       String?
  roleDefinition RoleDefinition? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isActive     Boolean     @default(true)
  technician   Technician?
  payments     Payment[]
  assignedTasks EssentialTask[]
  otpChallenges AuthOtpChallenge[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([roleId])
}

model AuthOtpChallenge {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model RoleDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  homePath    String   @default("/my-tasks")
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Contact {
  id        String    @id @default(cuid())
  fullName  String
  phone     String
  email     String?
  address   String?
  repairs   Repair[]
  invoices  Invoice[]
  reservations Reservation[]
  abonnements Abonnement[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Abonnement {
  id        String            @id @default(cuid())
  contactId String
  contact   Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  label     String
  startsAt  DateTime
  endsAt    DateTime
  amount    Decimal           @default(0) @db.Decimal(12, 2)
  status    AbonnementStatus  @default(ACTIVE)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([contactId])
  @@index([startsAt])
  @@index([endsAt])
  @@index([status])
}

model Reservation {
  id            String            @id @default(cuid())
  contactId     String?
  contact       Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  clientName    String
  startsAt      DateTime
  endsAt        DateTime
  tableName     String?
  location      String            @default("Magasin principal")
  servicePerson String?
  status        ReservationStatus @default(BOOKED)
  notes         String?
  recurrenceId  String?
  createdBy     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([startsAt])
  @@index([location])
  @@index([contactId])
}

model Technician {
  id           String                 @id @default(cuid())
  userId       String                 @unique
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty    String?
  repairs      Repair[]
  partRequests PartRequest[]
  commissions  TechnicianCommission[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model Brand {
  id        String        @id @default(cuid())
  name      String        @unique
  devices   DeviceModel[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Device {
  id        String        @id @default(cuid())
  name      String        @unique
  models    DeviceModel[]
  repairs   Repair[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model DeviceModel {
  id        String   @id @default(cuid())
  name      String
  brandId   String
  deviceId  String
  brand     Brand    @relation(fields: [brandId], references: [id])
  device    Device   @relation(fields: [deviceId], references: [id])
  repairs   Repair[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brandId, deviceId, name])
}

model Product {
  id           String            @id @default(cuid())
  name         String
  sku          String            @unique
  barcode      String?
  brand        String?
  category     String?
  unit         String?
  warranty     String?
  productType  String?
  description  String?
  unitPrice    Decimal           @db.Decimal(12, 2)
  taxRate      Decimal           @default(0) @db.Decimal(5, 2)
  stockQty     Int               @default(0)
  minStockQty  Int               @default(0)
  movements    StockMovement[]
  requestItems PartRequestItem[]
  invoiceItems InvoiceItem[]
  purchaseItems PurchaseItem[]
  stockTransferItems StockTransferItem[]
  stockAdjustmentItems StockAdjustmentItem[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model StockAdjustment {
  id              String              @id @default(cuid())
  reference       String              @unique
  adjustmentDate  DateTime            @default(now())
  location        String
  type            StockAdjustmentType
  total           Decimal             @default(0) @db.Decimal(12, 2)
  recoveredAmount Decimal             @default(0) @db.Decimal(12, 2)
  reason          String?
  addedBy         String
  items           StockAdjustmentItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([adjustmentDate])
  @@index([location])
}

model StockAdjustmentItem {
  id           String          @id @default(cuid())
  adjustmentId String
  adjustment   StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Decimal         @db.Decimal(12, 2)
  lineTotal    Decimal         @db.Decimal(12, 2)
}

model StockTransfer {
  id              String              @id @default(cuid())
  reference       String              @unique
  transferDate    DateTime            @default(now())
  fromLocation    String
  toLocation      String
  status          StockTransferStatus @default(PENDING)
  shippingCharges Decimal             @default(0) @db.Decimal(12, 2)
  notes           String?
  total           Decimal             @default(0) @db.Decimal(12, 2)
  addedBy         String
  items           StockTransferItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([transferDate])
  @@index([fromLocation, toLocation])
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Decimal       @db.Decimal(12, 2)
  lineTotal  Decimal       @db.Decimal(12, 2)
}

model Purchase {
  id            String                @id @default(cuid())
  reference     String                @unique
  kind          PurchaseKind          @default(PURCHASE)
  supplierName  String
  location      String                @default("Magasin principal")
  status        PurchaseStatus        @default(DRAFT)
  paymentStatus PurchasePaymentStatus @default(UNPAID)
  purchaseDate  DateTime              @default(now())
  subtotal      Decimal               @default(0) @db.Decimal(12, 2)
  discount      Decimal               @default(0) @db.Decimal(12, 2)
  tax           Decimal               @default(0) @db.Decimal(12, 2)
  shipping      Decimal               @default(0) @db.Decimal(12, 2)
  total         Decimal               @default(0) @db.Decimal(12, 2)
  paidAmount    Decimal               @default(0) @db.Decimal(12, 2)
  notes         String?
  addedBy       String
  items         PurchaseItem[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([kind, purchaseDate])
  @@index([supplierName])
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  quantity    Int
  unitCost    Decimal  @db.Decimal(12, 2)
  margin      Decimal  @default(0) @db.Decimal(5, 2)
  salePrice   Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)
}

model StockMovement {
  id        String            @id @default(cuid())
  productId String
  product   Product           @relation(fields: [productId], references: [id])
  type      StockMovementType
  quantity  Int
  reason    String?
  repairId  String?
  repair    Repair?           @relation(fields: [repairId], references: [id])
  createdAt DateTime          @default(now())
}

model Repair {
  id             String           @id @default(cuid())
  reference      String           @unique
  contactId      String
  contact        Contact          @relation(fields: [contactId], references: [id])
  deviceId       String
  device         Device           @relation(fields: [deviceId], references: [id])
  deviceModelId  String?
  deviceModel    DeviceModel?     @relation(fields: [deviceModelId], references: [id])
  technicianId   String?
  technician     Technician?      @relation(fields: [technicianId], references: [id])
  status         String           @default("RECEIVED")
  imei           String?
  devicePassword String?
  lockReason     String?
  problem        String
  diagnosis      String?
  notes          String?
  photos         String[]         @default([])
  estimatedCost  Decimal?         @db.Decimal(12, 2)
  timerLogs      RepairTimerLog[]
  partRequests   PartRequest[]
  invoices       Invoice[]
  stockMovements StockMovement[]
  repairTypeId   String?
  repairType     RepairType?      @relation(fields: [repairTypeId], references: [id], onDelete: SetNull)
  commissions    TechnicianCommission[]
  receivedAt     DateTime         @default(now())
  deliveredAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model RepairTimerLog {
  id          String    @id @default(cuid())
  repairId    String
  repair      Repair    @relation(fields: [repairId], references: [id], onDelete: Cascade)
  startedAt   DateTime
  endedAt     DateTime?
  durationSec Int?
  createdAt   DateTime  @default(now())
}

model PartRequest {
  id              String            @id @default(cuid())
  repairId        String
  repair          Repair            @relation(fields: [repairId], references: [id], onDelete: Cascade)
  technicianId    String
  technician      Technician        @relation(fields: [technicianId], references: [id])
  status          PartRequestStatus @default(PENDING)
  reason          String?
  rejectionReason String?
  items           PartRequestItem[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model PartRequestItem {
  id            String      @id @default(cuid())
  partRequestId String
  partRequest   PartRequest @relation(fields: [partRequestId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  repairId      String?
  repair        Repair?       @relation(fields: [repairId], references: [id])
  contactId     String
  contact       Contact       @relation(fields: [contactId], references: [id])
  paymentStatus PaymentStatus @default(UNPAID)
  documentType InvoiceDocumentType @default(SALE)
  status       String        @default("FINAL")
  shippingStatus String      @default("NOT_SHIPPED")
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(12, 2)
  items         InvoiceItem[]
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SalesDiscount {
  id          String   @id @default(cuid())
  name        String
  priority    Int      @default(1)
  brand       String?
  category    String?
  location    String?
  productType String?
  amount      Decimal  @db.Decimal(12, 2)
  amountType  String   @default("FIXED")
  startsAt    DateTime?
  endsAt      DateTime?
  customerGroup String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SalesImport {
  id          String   @id @default(cuid())
  fileName    String
  invoiceCount Int     @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
}

model ExpenseCategory {
  id              String            @id @default(cuid())
  name            String
  code            String?
  parentId        String?
  parent          ExpenseCategory?  @relation("ExpenseCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        ExpenseCategory[] @relation("ExpenseCategoryTree")
  expenses        Expense[]         @relation("ExpenseCategoryMain")
  subExpenses     Expense[]         @relation("ExpenseCategorySub")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([name, parentId])
}

model Expense {
  id              String           @id @default(cuid())
  reference       String           @unique
  location        String
  categoryId      String
  category        ExpenseCategory  @relation("ExpenseCategoryMain", fields: [categoryId], references: [id])
  subCategoryId   String?
  subCategory     ExpenseCategory? @relation("ExpenseCategorySub", fields: [subCategoryId], references: [id])
  expenseDate     DateTime          @default(now())
  expenseFor      String
  contact         String?
  applicableTax   String?
  total           Decimal          @db.Decimal(12, 2)
  note            String?
  attachmentName  String?
  isRecurring     Boolean          @default(false)
  recurrenceEvery Int?
  recurrenceUnit  String?
  occurrences     Int?
  paymentAmount   Decimal          @default(0) @db.Decimal(12, 2)
  paymentDate     DateTime?
  paymentMethod   String?
  paymentAccount  String?
  paymentNote     String?
  addedBy         String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([expenseDate])
  @@index([categoryId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  cashierId String
  cashier   User     @relation(fields: [cashierId], references: [id])
  amount    Decimal  @db.Decimal(12, 2)
  method    String
  reference String?
  paymentAccountId String?
  paymentAccount PaymentAccount? @relation(fields: [paymentAccountId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model PaymentAccount {
  id             String               @id @default(cuid())
  name           String
  accountType    String
  accountNumber  String?              @unique
  description    String?
  initialBalance Decimal              @default(0) @db.Decimal(12, 2)
  isActive       Boolean              @default(true)
  createdBy      String
  transactions   AccountTransaction[]
  payments       Payment[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model AccountTransaction {
  id            String                      @id @default(cuid())
  accountId     String
  account       PaymentAccount              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactionDate DateTime                   @default(now())
  reference     String?
  invoiceReference String?
  amount        Decimal                     @db.Decimal(12, 2)
  paymentType   String?
  direction     AccountTransactionDirection
  description   String?
  createdBy     String
  createdAt     DateTime                    @default(now())

  @@index([transactionDate])
  @@index([accountId])
}

model EssentialTask {
  id             String                @id @default(cuid())
  reference      String                @unique
  title          String
  status         EssentialTaskStatus   @default(NEW)
  priority       EssentialTaskPriority @default(MEDIUM)
  startAt        DateTime?
  endAt          DateTime?
  estimatedHours String?
  assignedTo     String
  assignedUserId String?
  assignedUser   User?                  @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  documents      String[]              @default([])
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([assignedUserId])
}

model RepairType {
  id              String                 @id @default(cuid())
  name            String                 @unique
  commissionRate  Decimal                @default(0) @db.Decimal(12, 2)
  managedByAdmin  Boolean                @default(false)
  repairs         Repair[]
  commissions     TechnicianCommission[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model TechnicianStatusMapping {
  id        String   @id @default(cuid())
  event     String   // "REPAIR_STARTED" | "REPAIR_COMPLETED" | "RETURN_SAV" | "BROKEN_LOST"
  statusId  String
  status    String   // The repair status value (e.g. "IN_PROGRESS", "FINISHED", custom status names)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([event, status])
}

model TechnicianCommission {
  id               String      @id @default(cuid())
  technicianId     String
  technician       Technician  @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  repairId         String
  repair           Repair      @relation(fields: [repairId], references: [id], onDelete: Cascade)
  repairTypeId     String?
  repairType       RepairType? @relation(fields: [repairTypeId], references: [id], onDelete: SetNull)
  commissionBrute  Decimal     @default(0) @db.Decimal(12, 2)
  deductionRetour  Decimal     @default(0) @db.Decimal(12, 2)
  deductionPerte   Decimal     @default(0) @db.Decimal(12, 2)
  commissionNette  Decimal     @default(0) @db.Decimal(12, 2)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model CustomStatus {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  color     String   @default("#94a3b8")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GrhRecord {
  id          String   @id @default(cuid())
  type        String
  name        String
  description String?
  data        Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([type, name])
}

model CrmRecord {
  id          String   @id @default(cuid())
  type        String
  name        String
  description String?
  status      String?
  data        Json     @default("{}")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([type, name])
}

model ProjectCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Project {
  id           String           @id @default(cuid())
  name         String
  description  String?
  status       String           @default("NOT_STARTED")
  startDate    DateTime?
  endDate      DateTime?
  categoryId   String?
  category     ProjectCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  customFields Json             @default("{}")
  createdBy    String
  tasks        ProjectTask[]
  timeLogs     ProjectTimeLog[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status])
  @@index([categoryId])
}

model ProjectTask {
  id           String           @id @default(cuid())
  projectId    String
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subject      String
  description  String?
  status       String           @default("TODO")
  priority     String           @default("MEDIUM")
  assignedTo   String?
  startDate    DateTime?
  endDate      DateTime?
  customFields Json             @default("{}")
  timeLogs     ProjectTimeLog[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([projectId, status])
}

model ProjectTimeLog {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      ProjectTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  userName  String
  minutes   Int
  note      String?
  loggedAt  DateTime     @default(now())

  @@index([projectId])
  @@index([taskId])
}

model ProjectSettings {
  id           String   @id @default("default")
  customField1 String?
  customField2 String?
  customField3 String?
  customField4 String?
  updatedAt    DateTime @updatedAt
}
